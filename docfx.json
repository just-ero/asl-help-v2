{
  "build": {
    "template": "default"
  },
  "metadata": [
    {
      "memberLayout": "separatePages",
      "outputFormat": "markdown",
      "output": "./docs",
      "src": [
        {
          "src": "./src",
          "files": [
            "**/*.csproj"
          ]
        },
        {
          "src": "./impl",
          "files": [
            "**/*.csproj"
          ]
        }
      ]
    }
  ]
}
